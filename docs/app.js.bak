document.addEventListener('DOMContentLoaded', () => {
    const scoreBtn = document.getElementById('score-btn');
    const btnText = document.querySelector('.btn-text');
    const btnLoader = document.querySelector('.btn-loader');
    const resultsContainer = document.getElementById('results-container');
    const template = document.getElementById('result-template');

    scoreBtn.addEventListener('click', async () => {
        const text = document.getElementById('essay-input').value.trim();
        const promptId = document.getElementById('exam-select').value;

        if (!text) {
            alert('Please enter an essay to score.');
            return;
        }

        // UI Loading state
        scoreBtn.disabled = true;
        btnText.classList.add('hidden');
        btnLoader.classList.remove('hidden');

        try {
            const startStr = Date.now();

            // Call FastAPI backend
            const response = await fetch('/api/score', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    essay_id: "demo_" + startStr,
                    text: text,
                    prompt_id: parseInt(promptId)
                })
            });

            if (!response.ok) throw new Error('API processing failed');

            const data = await response.json();
            const latency = Date.now() - startStr;

            renderResults(data, latency, promptId);

        } catch (error) {
            console.error(error);
            resultsContainer.innerHTML = `<div class="empty-state" style="color: #ef4444;">Error: ${error.message}</div>`;
        } finally {
            scoreBtn.disabled = false;
            btnText.classList.remove('hidden');
            btnLoader.classList.add('hidden');
        }
    });

    function renderResults(data, latencyMs, promptId) {
        // Clear previous
        resultsContainer.innerHTML = '';

        // Clone template
        const clone = template.content.cloneNode(true);

        // Populate Score
        const scoreRing = clone.querySelector('.score-ring');
        const pct = (data.score / 6) * 100;
        scoreRing.style.setProperty('--score-pct', pct);

        clone.querySelector('.score-value').textContent = data.score;
        clone.querySelector('.conf-value').textContent = ((data.confidence || 0.92) * 100).toFixed(1);

        // Populate Justification
        clone.querySelector('.justification-text').textContent = data.justification;

        // Populate Trace
        const trace = clone.querySelector('.trace-list');
        trace.innerHTML = `
            <li>Base Model: <span class="trace-value">Llama-3.1-8B-Instruct (4-bit AWQ)</span></li>
            <li>Active LoRA: <span class="trace-value">Adapter Set ${promptId} (~17MB)</span></li>
            <li>Inference Engine: <span class="trace-value">vLLM Continuous Batching</span></li>
            <li>Latency: <span class="trace-value">${latencyMs}ms</span></li>
        `;

        resultsContainer.appendChild(clone);
    }
});
